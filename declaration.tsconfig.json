{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "declaration": true,
    "declarationMap": true,
    "noEmit": false,
    "emitDeclarationOnly": true,
    "removeComments": false
  },
  "exclude": [
    "**/*.test.js",
    "**/*.test.ts",
    "**/*.types.ts",
    "type-tests.ts",
    "node_modules",
    "coverage",
    ".github"
  ]
}
